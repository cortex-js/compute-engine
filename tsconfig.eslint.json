{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // This config also lints test/ and tutorials/, which live outside ./src
    // and rely on jest globals.
    "rootDir": ".",
    "types": ["node", "jest"]
  },
  "include": [
    ".eslintrc.js",
    "./src",
    "./test",
    "./tutorials",
    "./*.js",
    "**/*.js",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.less"
  ],
  "exclude": ["coverage", "node_modules", "dist", "build", "examples"]
}
