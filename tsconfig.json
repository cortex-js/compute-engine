{
  "compilerOptions": {
    // "allowJs": true,
    "declaration": true,
    "emitDecoratorMetadata": false,
    "esModuleInterop": true,
    "experimentalDecorators": false,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo", // Cache for incremental builds
    "lib": ["es2022", "dom", "dom.iterable", "scripthost"],
    "module": "es2022",
    "target": "es2022",
    // TS 6: "node" (node10) is deprecated/removed; "bundler" matches the
    // esbuild build pipeline and our extensionless relative imports.
    "moduleResolution": "bundler",
    // The identities entry imports the compiled rule artifact
    // (src/compute-engine/fungrim/fungrim-core-data.json)
    "resolveJsonModule": true,
    // TS 6 no longer auto-discovers @types/*; src uses `process.env`.
    "types": ["node"],
    "rootDir": "./src",
    // "newLine": "lf",
    "noLib": false,
    "removeComments": false,
    "sourceMap": true,
    // TS 6 enables strict by default; declared explicitly for clarity.
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true // Skip type checking of declaration files (faster)
    // "isolatedDeclarations": true
  },
  "include": ["src/**/*"]
}
