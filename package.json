{
  "version": "0.71.0",
  "scripts": {
    "doc": "bash ./scripts/doc.sh",
    "build": "bash ./scripts/build.sh",
    "clean": "bash ./scripts/clean.sh",
    "coverage": "bash ./scripts/test.sh coverage",
    "dist": "bash ./scripts/build.sh production; bash ./scripts/test.sh",
    "prepare": "bash ./scripts/build.sh production",
    "start": "bash ./scripts/start.sh",
    "snapshot": "bash ./scripts/test.sh snapshot",
    "version": "bash ./scripts/version.sh",
    "test": "bash ./scripts/test.sh",
    "test:nodenext": "node ./test/consumer/nodenext-smoke.mjs",
    "test:nightly": "CE_NIGHTLY=1 jest --config ./config/jest.config.cjs --reporters default -- test/compute-engine/nightly/",
    "check:deps": "madge --circular --extensions ts src/compute-engine && echo 'No runtime circular dependencies found (type-only cycles are expected)'",
    "lint": "eslint src --ext .ts --fix && prettier --write 'src/**/*.{ts,js,css,md}'",
    "typecheck": "bash ./scripts/typecheck.sh"
  },
  "name": "@cortex-js/compute-engine",
  "description": "Symbolic computing and numeric evaluations for JavaScript and Node.js",
  "homepage": "https://cortexjs.io/compute-engine/",
  "repository": {
    "type": "git",
    "url": "https://github.com/cortex-js/compute-engine.git"
  },
  "bugs": "https://github.com/cortex-js/compute-engine/issues/",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "math",
    "JSON",
    "mathjs",
    "mathematica",
    "maple",
    "algebra",
    "symbolic computing",
    "scientific computing",
    "sympy"
  ],
  "license": "MIT",
  "files": [
    "/dist/esm-min",
    "/dist/umd-min",
    "/dist/types"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/compute-engine.d.ts",
      "import": "./dist/esm-min/compute-engine.js",
      "require": "./dist/umd-min/compute-engine.cjs",
      "default": "./dist/esm-min/compute-engine.js"
    },
    "./math-json": {
      "types": "./dist/types/math-json.d.ts",
      "import": "./dist/esm-min/math-json.js",
      "require": "./dist/umd-min/math-json.cjs",
      "default": "./dist/esm-min/math-json.js"
    },
    "./latex-syntax": {
      "types": "./dist/types/latex-syntax.d.ts",
      "import": "./dist/esm-min/latex-syntax.js",
      "require": "./dist/umd-min/latex-syntax.cjs",
      "default": "./dist/esm-min/latex-syntax.js"
    },
    "./interval": {
      "types": "./dist/types/interval.d.ts",
      "import": "./dist/esm-min/interval.js",
      "require": "./dist/umd-min/interval.cjs",
      "default": "./dist/esm-min/interval.js"
    },
    "./numerics": {
      "types": "./dist/types/numerics.d.ts",
      "import": "./dist/esm-min/numerics.js",
      "require": "./dist/umd-min/numerics.cjs",
      "default": "./dist/esm-min/numerics.js"
    },
    "./core": {
      "types": "./dist/types/core.d.ts",
      "import": "./dist/esm-min/core.js",
      "require": "./dist/umd-min/core.cjs",
      "default": "./dist/esm-min/core.js"
    },
    "./compile": {
      "types": "./dist/types/compile.d.ts",
      "import": "./dist/esm-min/compile.js",
      "require": "./dist/umd-min/compile.cjs",
      "default": "./dist/esm-min/compile.js"
    },
    "./identities": {
      "types": "./dist/types/identities.d.ts",
      "import": "./dist/esm-min/identities.js",
      "require": "./dist/umd-min/identities.cjs",
      "default": "./dist/esm-min/identities.js"
    },
    "./integration-rules": {
      "types": "./dist/types/integration-rules.d.ts",
      "import": "./dist/esm-min/integration-rules.js",
      "require": "./dist/umd-min/integration-rules.cjs",
      "default": "./dist/esm-min/integration-rules.js"
    }
  },
  "main": "./dist/esm-min/compute-engine.js",
  "module": "./dist/esm-min/compute-engine.js",
  "browser": "./dist/umd-min/compute-engine.cjs",
  "unpkg": "./dist/umd-min/compute-engine.cjs",
  "types": "./dist/types/compute-engine.d.ts",
  "engines": {
    "npm": ">=10.5.0",
    "node": ">=21.7.3"
  },
  "devDependencies": {
    "@cortex-js/prettier-config": "^1.2.0",
    "@jest/console": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@typescript-eslint/typescript-estree": "^8.61.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "chalk": "^5.6.2",
    "check-node-version": "^4.2.1",
    "concat-md": "^0.5.1",
    "decimal.js": "^10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "~4.0.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.4.2",
    "jest-silent-reporter": "^0.6.0",
    "madge": "^8.0.0",
    "open": "^11.0.0",
    "prettier": "^3.8.1",
    "prettier-2": "npm:prettier@^2.8.8",
    "serve-http": "^1.0.7",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-plugin-no-inherit": "^1.6.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "update-notifier": "^7.3.1"
  },
  "prettier": "@cortex-js/prettier-config",
  "dependencies": {
    "@arnog/colors": "^0.5.0",
    "complex-esm": "^2.1.1-esm1"
  }
}
